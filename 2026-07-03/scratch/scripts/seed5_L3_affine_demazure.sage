# Let me first just count elements at different "depths"
# and see if the dimensions match

# The affine Weyl group element for "depth n":
# In the cylindric partition picture, increasing the bound from N to N+1
# corresponds to one application of some Demazure operator.

# Hypothesis: the Demazure module at depth n uses the word
# w_n = (s_0 s_1 s_2)^n or w_n = (s_1 s_2 s_0)^n

# Let me try various words and check dimensions

print("\nBuilding Demazure subcrystals...")
print(f"Target: Q_1(1) = 11 for c=(3,2,2)")

# Try all length-1 words
for i in [0, 1, 2]:
    elems = build_demazure_word(hw, [i])
    print(f"  Word [{i}]: {len(elems)} elements")

# Length-2 words
for i in [0,1,2]:
    for j in [0,1,2]:
        if i != j:
            elems = build_demazure_word(hw, [i,j])
            print(f"  Word [{i},{j}]: {len(elems)} elements")

# Length-3 words (single cycle)
for word in [[0,1,2], [0,2,1], [1,0,2], [1,2,0], [2,0,1], [2,1,0]]:
    elems = build_demazure_word(hw, word)
    print(f"  Word {word}: {len(elems)} elements")

# Also try words of the form s_0 s_1 s_2 s_0 etc. (longer)
for l in [4, 5, 6]:
    for start_word in [[0,1,2], [1,2,0], [2,0,1]]:
        word = []
        for k in range(l):
            word.append(start_word[k % 3])
        elems = build_demazure_word(hw, word)
        print(f"  Word {word}: {len(elems)} elements")

# The Q_0 = 1 (depth 0 = just highest weight)
# Q_1(1) = 11 (need 11 + 1 = 12 elements? or 11?)
# Q_1 counts objects, so depth 1 Demazure should have dim = Q_1(1) + 1 = 12
# (including the highest weight itself)
# Wait: Q_0 = 1, Q_1(1) = 11. The total F_{c,1}(1) = h_1(1) / (q;q)_1(1) ?
# h_0(1) = 1, h_1(1) = 12. So Q_1 = h_1 - q*h_0 -> Q_1(1) = 12 - 1 = 11.

# So we're looking for a Demazure crystal with 12 elements at "level 1"
# (where "level 1" includes the highest weight + 11 new elements)
# OR we need 11 elements at some grading level...

# Actually the Q polynomial is a character, not just a dimension.
# Q_1 = 2q + 3q^2 + 2q^3 + 2q^4 + q^5 + q^6
# So Q_1 has NO constant term. The q-degree corresponds to some grading.

# In the affine crystal, the natural grading is by the energy function
# or by the null root delta component of the weight.

# For LSPaths in affine type, the weight has the form:
# w = sum_i a_i Lambda_i + n*delta
# where n is related to the "level" or "depth"

# Let me compute weights more carefully
print("\n" + "="*60)
print("Weight analysis of Demazure subcrystals")
print("="*60)

# Use a moderate word
word_012 = [0, 1, 2]
elems = build_demazure_word(hw, word_012, max_size=1000)
print(f"\nDemazure crystal for word [0,1,2]: {len(elems)} elements")

# Examine weights
weight_lattice = RootSystem(['A',2,1]).weight_lattice()
Lambda = weight_lattice.fundamental_weights()

hw_weight = hw.weight()

for b in sorted(list(elems), key=lambda x: str(x))[:20]:
    wt = b.weight()
    # Compute the difference from highest weight
    diff = hw_weight - wt  # This might not work directly
    print(f"  {str(b)[:80]}...")
    print(f"    weight = {wt}")

# Try to understand the grading
print("\n" + "="*60)
print("Trying Demazure crystal with larger word for c=(3,2,2)")
print("="*60)

# The key insight might be that the "depth n" corresponds to
# applying the translation element t_alpha repeatedly.
# In type A_2^(1), the translation t_theta (theta = highest root = alpha_1 + alpha_2)
# is s_0 s_1 s_2 s_1 (or a similar expression).

# Actually in A_2^(1), a reduced expression for the translation is:
# For the fundamental weight omega_1: t_{omega_1} = s_1 s_0
# For omega_2: t_{omega_2} = s_2 s_1 s_0 s_2 (or similar)
# For theta = omega_1 + omega_2: more complex

# Let me try longer words systematically
target_dims = {0: 1, 1: 12, 2: 144, 3: 1728}  # h_m(1) = 12^m

for length in range(1, 10):
    # Try cyclic word [0,1,2,0,1,2,...] of this length
    word = [(i % 3) for i in range(length)]  # [0,1,2,0,1,2,...]
    elems = build_demazure_word(hw, word, max_size=5000)
    dim = len(elems)
    note = ""
    for n, target in target_dims.items():
        if dim == target:
            note = f" = h_{n}(1) = 12^{n}"
    print(f"  Word {word}: dim = {dim}{note}")

# Also try [1,2,0,...] and [2,0,1,...]
for start in [1, 2]:
    for length in range(1, 10):
        word = [((start + i) % 3) for i in range(length)]
        elems = build_demazure_word(hw, word, max_size=5000)
        dim = len(elems)
        note = ""
        for n, target in target_dims.items():
            if dim == target:
                note = f" = h_{n}(1) = 12^{n}"
        print(f"  Word {word}: dim = {dim}{note}")
