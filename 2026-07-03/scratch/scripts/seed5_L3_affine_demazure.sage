"""
Seed 5, Layer 3: Attempt to match Q_{n,c}(q) with affine Demazure characters.

The hypothesis: Q_{n,c}(q) is the principally specialized character of a Demazure
module in hat{sl}_3 at level d.

Profile c = (c0,c1,c2) -> highest weight Lambda = c0*Lambda_0 + c1*Lambda_1 + c2*Lambda_2

We explore Demazure subcrystals of the LSPaths crystal.
"""

R_poly = PolynomialRing(ZZ, 'q')
q_var = R_poly.gen()

# Q values for reference
Q1_322 = 2*q_var + 3*q_var**2 + 2*q_var**3 + 2*q_var**4 + q_var**5 + q_var**6
Q1_421 = 2*q_var + 2*q_var**2 + 2*q_var**3 + 2*q_var**4 + q_var**5 + q_var**6 + q_var**8

print("="*60)
print("Exploring affine A_2^(1) crystals")
print("="*60)

# Type A_2^(1) has nodes 0, 1, 2
# Create LSPaths crystal for level-7 weight (3,2,2) -> 3*Lambda_0 + 2*Lambda_1 + 2*Lambda_2
C = crystals.LSPaths(['A',2,1], [3,2,2])
print(f"Crystal: {C}")

hw = list(C.highest_weight_vectors())[0]
print(f"Highest weight: {hw}")
print(f"Weight: {hw.weight()}")

# In affine type A_2^(1), the crystal operators are f_0, f_1, f_2
# The finite-type subalgebra uses only f_1, f_2

# For Demazure modules, we need to specify a Weyl group element w.
# The relevant w should correspond to "depth n" in some sense.

# The affine Weyl group of A_2^(1) is generated by s_0, s_1, s_2
# Key elements:
# - Translation elements: t_alpha for alpha in the root lattice
# - The element tau = s_0 s_1 s_2 has some periodicity properties

# For the cylindric partition connection, the "depth n" should correspond
# to the translation element t^n or (s_0 s_1 s_2)^n or similar.

# Let me build Demazure subcrystals for various words and compute characters

def build_demazure_word(root, word, max_size=50000):
    """Build Demazure crystal for a given word [i_1, i_2, ..., i_k].
    Apply f_{i_k}, then f_{i_{k-1}}, etc. (reading from right to left).
    The Demazure crystal D_w(Lambda) consists of all b reachable from
    the highest weight by applying f_i in the order given by the word."""

    # Standard definition: for w = s_{i1}...s_{ik} (reduced),
    # B_w = f_{i1}^* ... f_{ik}^* {b_Lambda}
    # where f_i^* B = {f_i^j b : b in B, j >= 0}

    elements = {root}
    # Apply operators right to left
    for i in reversed(word):
        new_elements = set(elements)
        for b in list(elements):
            current = b
            while True:
                next_b = current.f(i)
                if next_b is None or next_b in new_elements:
                    break
                new_elements.add(next_b)
                current = next_b
                if len(new_elements) > max_size:
                    print(f"  WARNING: hit max_size {max_size}")
                    return new_elements
        elements = new_elements
    return elements

